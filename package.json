{
  "name": "experiment-ai-agents",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "run-s gen:css build:next",
    "build:next": "next build",
    "build-storybook": "storybook build",
    "check-code": "run-p --aggregate-output --print-label \"gen:*\" && run-p --aggregate-output --print-label \"lint:*\" test",
    "dev": "run-p --aggregate-output --print-label \"dev:*\"",
    "dev:css-modules-types": "hcm 'src/**/*.module.css' --watch",
    "dev:next": "next dev",
    "fix": "run-p --aggregate-output --print-label \"fix:*\"",
    "fix:css": "stylelint \"src/**/*.module.css\" --fix",
    "fix:eslint": "eslint . --fix",
    "fix:format": "prettier --write .",
    "fix:package-json": "sort-package-json package.json",
    "gen": "run-p --aggregate-output --print-label \"gen:*\"",
    "gen:css": "hcm 'src/**/*.module.css'",
    "lint": "run-p --aggregate-output --print-label \"lint:*\"",
    "lint:css": "stylelint \"src/**/*.module.css\"",
    "lint:eslint": "eslint .",
    "lint:format": "prettier --check .",
    "lint:package-json": "sort-package-json --check package.json",
    "lint:spell": "cspell \"**/*\" --no-progress",
    "lint:type": "tsc --noEmit",
    "start": "next start",
    "storybook": "storybook dev -p 6006",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "next": "16.2.10",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@cspell/cspell-types": "^10.0.1",
    "@eslint/eslintrc": "^3.3.6",
    "@eslint/js": "^9.39.5",
    "@next/eslint-plugin-next": "16.2.10",
    "@storybook/addon-a11y": "^10.5.3",
    "@storybook/addon-docs": "^10.5.3",
    "@storybook/nextjs": "^10.5.3",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^7.0.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@tsconfig/strictest": "^2.0.8",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "cspell": "^10.0.1",
    "eslint": "^9.39.5",
    "eslint-config-prettier": "^10.1.8",
    "eslint-config-sc-all": "^0.2.1",
    "eslint-config-sc-jest": "^0.2.1",
    "eslint-config-sc-js": "^0.2.1",
    "eslint-config-sc-next": "^0.2.1",
    "eslint-config-sc-react": "^0.2.1",
    "eslint-config-sc-storybook": "^0.2.1",
    "eslint-config-sc-ts": "^0.2.1",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jest": "^29.15.5",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-storybook": "0.12.0",
    "eslint-plugin-unicorn": "^65.0.0",
    "happy-css-modules": "^5.0.2",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "npm-run-all2": "^9.0.2",
    "postcss": "^8.5.22",
    "prettier": "^3.9.6",
    "sort-package-json": "^4.0.0",
    "storybook": "^10.5.3",
    "stylelint": "^17.14.1",
    "stylelint-config-css-modules": "^4.6.0",
    "stylelint-config-standard": "^40.0.0",
    "ts-node": "^10.9.2",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.65.0"
  },
  "packageManager": "pnpm@10.34.5+sha512.a4ee05f2f73658255bd6a89859c065a45c28a57daefae2c893a168ee2b73168c37b91e83e57ea67654ad03f03031746430e8bce38e362e042605fb8abc80192e",
  "engines": {
    "node": ">=26.5.0",
    "pnpm": ">=10.34.5"
  }
}
