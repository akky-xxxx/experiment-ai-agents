{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git status:*)",
      "Bash(pnpm install)",
      "Bash(pnpm check-code)",
      "Bash(pnpm lint)",
      "Bash(pnpm fix)",
      "Bash(pnpm spell-check)",
      "Bash(pnpm ws-check-code)"
    ],
    "ask": [
      "Bash(pnpm add:*)",
      "Bash(pnpm dlx:*)",
      "Bash(pnpm exec:*)",
      "Bash(pnpm link:*)",
      "Bash(pnpm remove:*)",
      "Bash(pnpm unlink:*)",
      "Bash(pnpm update:*)"
    ],
    "deny": [
      "Bash(curl:*)",
      "Bash(git push:*)",
      "Bash(node -e:*)",
      "Bash(node -p:*)",
      "Bash(npx:*)",
      "Bash(pnpm publish:*)",
      "Bash(python3:*)",
      "Bash(python:*)",
      "Bash(wget:*)",
      "Edit(.claude/settings.local.json)",
      "Write(.claude/settings.local.json)"
    ]
  }
}
